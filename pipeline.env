PROFILE=hpc
RESUME=false
RESET_OUTPUTS=true
RUN_ID=fullrun_20260320
START_FROM=

PIPELINES_ROOT=/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines
SAMPLES_MASTER=/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines/nextflow-chipseq/samples_master.csv
