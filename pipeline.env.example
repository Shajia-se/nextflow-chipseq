# Copy to pipeline.env and edit values

# Basic
PROFILE=hpc
RESUME=true
PIPELINES_ROOT=/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines
OUTPUT_PROJECT_ROOT=/ictstr01/groups/idc/projects/uhlenhaut/jiang/runs/tr4_chipseq
RUN_ID=
RESET_OUTPUTS=false
START_FROM=

# Master metadata (required)
SAMPLES_MASTER=${PIPELINES_ROOT}/nextflow-chipseq/samples_master.csv

# Reference / annotation
REFERENCE_ROOT=/ictstr01/groups/idc/projects/uhlenhaut/jiang/reference
GENOME_RELEASE=GRCm39
GENCODE_VERSION=vM27
REFERENCE_FASTA=${REFERENCE_ROOT}/bwa/${GENOME_RELEASE}_${GENCODE_VERSION}/GRCm39.primary_assembly.genome.fa
GTF=${REFERENCE_ROOT}/gtf/gencode.${GENCODE_VERSION}.primary_assembly.annotation.gtf

# Core analysis thresholds
MAPQ_THRESHOLD=24
MACS3_QVALUE_IDR=0.1
MACS3_QVALUE_CONSENSUS=0.05
MACS3_QVALUE_STRICT=0.01
MACS3_RUN_IDR_BRANCH=
MACS3_RUN_CONSENSUS_BRANCH=true
MACS3_RUN_STRICT_BRANCH=

# Optional explicit sheets (leave empty to use samples_master auto mode)
MACS3_SAMPLESHEET=
IDR_PAIRS_CSV=
DIFFBIND_SAMPLESHEET=
FRIP_SAMPLESHEET=
DEEPTOOLS_REGIONS_SHEET=
HOMER_MOTIF_COMPARE_SHEET=
CONSENSUS_PAIRS_CSV=

# Optional peak-source overrides for downstream modules.
# Leave empty to auto-select from enabled upstream branches.
# Typical values now include:
#   FRIP_PEAK_SOURCES=idr,consensus_q0.01,consensus_q0.05
#   CHIPSEEKER_PEAK_SOURCES=idr,consensus_q0.01,consensus_q0.05,diffbind
#   HOMER_PEAK_SOURCES=idr,consensus_q0.01,consensus_q0.05
FRIP_PEAK_SOURCES=
CHIPSEEKER_PEAK_SOURCES=
HOMER_PEAK_SOURCES=

# Optional toggles
RUN_FASTQC=true
RUN_FASTP=true
RUN_BWA=true
RUN_PICARD=true
RUN_CHIPFILTER=true
RUN_MACS3=true
RUN_IDR=true
RUN_BAMCOVERAGE=true
RUN_FRIP=true
RUN_CHIPSEEKER=true
RUN_HOMER=true
RUN_HOMER_MOTIF_COMPARE=true
RUN_DEEPTOOLS_HEATMAP=true
RUN_PEAK_CONSENSUS=true
RUN_DIFFBIND=true
RUN_RESULT_DELIVERY=true
RUN_MULTIQC=true

# Optional output tag for result-delivery
DELIVERY_TAG=
DELIVERY_LEVEL=lean

# Optional MultiQC settings
MULTIQC_TITLE='ChIP-seq Pipeline Summary'
MULTIQC_REPORT_NAME=multiqc_report.html
# Comma-separated extra directories to scan
MULTIQC_EXTRA_PATHS=
# Optional custom MultiQC config YAML
MULTIQC_CONFIG=
