# Copy to pipeline.env and edit values

# Basic
PROFILE=hpc
RESUME=true
PIPELINES_ROOT=/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines
RUN_ID=
RESET_OUTPUTS=false
START_FROM=

# Master metadata (required)
SAMPLES_MASTER=${PIPELINES_ROOT}/nextflow-chipseq/samples_master.csv

# Reference / annotation
REFERENCE_FASTA=/ictstr01/groups/idc/projects/uhlenhaut/jiang/reference/bwa/GRCm39_primary_assembly/GRCm39.primary_assembly.genome.fa
GTF=/ictstr01/groups/idc/projects/uhlenhaut/jiang/reference/gtf/gencode.vM34.primary_assembly.annotation.gtf

# Optional explicit sheets (leave empty to use samples_master auto mode)
MACS3_SAMPLESHEET=
IDR_PAIRS_CSV=
DIFFBIND_SAMPLESHEET=
FRIP_SAMPLESHEET=
DEEPTOOLS_REGIONS_SHEET=
HOMER_MOTIF_COMPARE_SHEET=
CONSENSUS_PAIRS_CSV=

# Optional peak-source overrides for downstream modules.
# Leave empty to auto-select from enabled upstream branches.
FRIP_PEAK_SOURCES=
CHIPSEEKER_PEAK_SOURCES=
HOMER_PEAK_SOURCES=

# Optional toggles
RUN_FASTQC=true
RUN_FASTP=true
RUN_BWA=true
RUN_PICARD=true
RUN_CHIPFILTER=true
RUN_MACS3=true
RUN_IDR=true
RUN_BAMCOVERAGE=true
RUN_FRIP=true
RUN_CHIPSEEKER=true
RUN_HOMER=true
RUN_HOMER_MOTIF_COMPARE=true
RUN_DEEPTOOLS_HEATMAP=true
RUN_PEAK_CONSENSUS=true
RUN_DIFFBIND=true
RUN_RESULT_DELIVERY=true
RUN_MULTIQC=true

# Optional output tag for result-delivery
DELIVERY_TAG=
DELIVERY_LEVEL=lean

# Optional MultiQC settings
MULTIQC_TITLE='ChIP-seq Pipeline Summary'
MULTIQC_REPORT_NAME=multiqc_report.html
# Comma-separated extra directories to scan
MULTIQC_EXTRA_PATHS=
# Optional custom MultiQC config YAML
MULTIQC_CONFIG=
