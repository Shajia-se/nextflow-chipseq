# Copy to pipeline.env and edit values

# Basic
PROFILE=hpc
RESUME=true
PIPELINES_ROOT=/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines
RUN_ID=
RESET_OUTPUTS=false

# Master metadata (required)
SAMPLES_MASTER=${PIPELINES_ROOT}/nextflow-chipseq/samples_master.csv

# Reference / annotation
REFERENCE_FASTA=/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines/reference/Mus_musculus/GRCm39/toplevel_bwa/index.fa
GTF=/ictstr01/groups/idc/projects/uhlenhaut/jiang/reference/gtf/mm39.gencode.vM34.annotation.gtf

# Optional explicit sheets (leave empty to use samples_master auto mode)
MACS3_SAMPLESHEET=
IDR_PAIRS_CSV=
DIFFBIND_SAMPLESHEET=
FRIP_SAMPLESHEET=
DEEPTOOLS_REGIONS_SHEET=
HOMER_MOTIF_COMPARE_SHEET=

# Optional toggles
RUN_HOMER_MOTIF_COMPARE=true
RUN_DEEPTOOLS_HEATMAP=true
RUN_DIFFBIND=true
RUN_RESULT_DELIVERY=true
RUN_MULTIQC=true

# Optional output tag for result-delivery
DELIVERY_TAG=
DELIVERY_LEVEL=lean

# Optional MultiQC settings
MULTIQC_TITLE='ChIP-seq Pipeline Summary'
MULTIQC_REPORT_NAME=multiqc_report.html
# Comma-separated extra directories to scan
MULTIQC_EXTRA_PATHS=
# Optional custom MultiQC config YAML
MULTIQC_CONFIG=
